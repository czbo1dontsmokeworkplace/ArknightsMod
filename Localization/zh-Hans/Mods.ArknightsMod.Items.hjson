KingsArmor: {
	DisplayName: 国王的铠甲
	Tooltip:
		'''
		将最大生命值的30%转换为防御力
		每10点生命转换为1防御力
		增加3点基础防御力，击败肉山、机械三王、世纪之花、拜月教徒、月球领主均可增加基础防御力
		击败boss最高可获得20基础防御力
		"王宫的大门前、广场上，曾摆放着那么多金色的展柜，四方珍品尽供欣赏而现在，仅仅是回想那个场面就会让人受伤"
		'''
}

KingsCrown: {
	DisplayName: 诸王的冠冕
	Tooltip:
		'''
		当前生命值小于等于最大生命值的30%时+50%伤害
		装备3个及以上的国王收藏品则改为+150%伤害
		"无名的诸王啊，纵使王国毁灭，仍愿您护佑伊比利亚"
		'''
}

KingsStaff: {
	DisplayName: 国王的延伸
	Tooltip:
