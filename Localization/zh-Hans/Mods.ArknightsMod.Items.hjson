		                     ——《罗德岛野外生存指南》
		'''
}

EmperorCollection: {
	DisplayName: 皇帝的收藏
	Tooltip:
		'''
		所有敌方单位受到的法术和召唤伤害+30%
		萨米人对他们的荒野尊崇无比，而现在这片荒野的碎片正静静躺在乌萨斯皇帝的私库中
		'''
}

FallenSovereignForm: {
	DisplayName: 王命凡形
	Tooltip:
		'''
		防御+15，将70%的最大生命值转换为等量的“护盾”来承受伤害
		护盾存在时，承受的伤害会受到一定比例易伤加成
		生命值强制限制在最大生命值的30%
		王各有命，形亦不同
		'''
}

Feardriedfish: {
	DisplayName: 恐鱼干
	Tooltip:
		'''
		所有敌方单位的防御力-21%
		当生存的欲望压过恐惧后，饥不择食的伊比利亚人会吞下这些“食物”
		然后在某个平常的日子里成为恐鱼
		'''
}

FeatherBeastLiverPate: {
	DisplayName: 羽兽肝酱
	Tooltip:
		'''
		所有自然回复技能的技力恢复+0.35/秒
		小瓶高档羽兽肝酱，颜色鲜艳，贵族特供
		'''
}

MonarchSidearm: {
	DisplayName: 国王的新枪
	Tooltip:
		'''
		生命值低于30%时，所有武器以及工具的使用速度+50%
		绝境下的美好祈愿能带给人希望，即使那并不是真相
		'''
}

NobleSwords: {
	DisplayName: 贵族刺剑
	Tooltip:
		'''
		近战类型武器的攻击力+25%
		装饰性强的贵族刺剑高卢贵族首先使用，作为军事武器还是太脆了
		'''
}

PaleCorolla: {
	DisplayName: 苍白花冠
	Tooltip:
		'''
		受到的治疗回复效果+30%
		生命恢复速度+30%
		血魔仪式使用的花冠头纱，曾经鲜红的生命被吮吸殆尽，现在只余苍白
		'''
}

SilverDinnerFork: {
	DisplayName: 银餐叉
	Tooltip:
		'''
		远程类型武器的攻击力+25%
		一把用来处理失败的演员，一把用来收拾蹩脚的剧作者，还有一把留给有需要的人
		厨师长不能容忍任何人在餐桌上出错
		'''
}

StandardAntiRiotEquipment: {
	DisplayName: 制式防暴用具
	Tooltip:
		'''
		所有敌方单位受到的法术和召唤伤害+20%
		乌萨斯军警的制式装备，自带施放间歇性致盲源石技艺的功能
		可惜关键时刻想得起来这一功能的军警寥寥无几
		'''
}

SuspendedSilkPuppet: {
	DisplayName: 悬丝傀儡
	Tooltip:
		'''
		敌人受到[c/FF6A6A:着火了！],[c/FF6A6A:中毒],[c/FF6A6A:诅咒狱火]等debuff时每秒受到70点无来源伤害
		越是用力想要挣脱，丝线就缠得越紧，你真的认为自己仍在思考？
		'''
}

TheLongWhipOfTheCoachman: {
	DisplayName: 赶车夫的长鞭
	Tooltip:
		'''
		所有敌方单位受到的近战和远程伤害+25%
		作为剧团的赶车人，他没有名字，没有过往
		唯有挥鞭驱赶驮兽，他的生命才有意义
		'''
}

ChildlikePlaythings: {
	DisplayName: “童趣玩偶”
	Tooltip:
		'''
		敌人受到[c/FF6A6A:着火了！],[c/FF6A6A:中毒],[c/FF6A6A:诅咒狱火]等debuff时每秒受到100点无来源伤害
		伊比利亚的孩童们将海岸边的奇物做成了简陋玩偶，听说只要抱着它，梦乡就会变得充实起来
		'''
}

DamagedRevolverNest: {
	DisplayName: 损坏的左轮弹巢
	Tooltip:
		'''
		远程类型武器的攻击力+35%
		她行过刀山火海也不曾有一刻向奸邪低头，她枪口火舌焦灼好似怒阳，她头顶光芒炽烈几胜白昼
		此处安葬着Outcast，我们的朋友
		'''
}

DreamEssence: {
	DisplayName: 迷梦香精
	Tooltip:
		'''
		所有自然回复技能的技力恢复+0.5/秒
		据说女妖们制作的香氛只会送给心上之人
		只需一滴，就能令人如痴如醉，而艺术家们的灵感与创意也随之而来
		'''
}

FearlessBlade: {
	DisplayName: 无惧之刃
	Tooltip:
		'''
		玩家背包内稀有度最高的一把武器+50%伤害
		玩家装备栏以及背包内稀有度最高的一件防具+50%防御
		他站在城门前，为卡兹戴尔守住这处门户
		高卢火炮队、莱塔尼亚术师团、维多利亚骑士轮番上阵，想要突破这只有一名萨卡兹的防线
		可直到城门被轰碎，直到联军决定撤退，这位歌利亚剑士都没有后退一步
		'''
}

OldPalmFan: {
	DisplayName: 老蒲扇
	Tooltip:
		'''
		当前世界中，每存在一名城镇NPC，玩家的攻击力+3%
		遇上连天阴雨，大炎的老天师便会向亲友抱怨自己膝盖受不得湿寒，然后，随手扇动他的蒲扇...
		云开雾散，雨水退避，天气就此放晴这一手，下回还得教教他那在大理寺当差的小徒弟
		'''
}

RoundStoneAltar: {
	DisplayName: 圆石祭坛
	Tooltip:
