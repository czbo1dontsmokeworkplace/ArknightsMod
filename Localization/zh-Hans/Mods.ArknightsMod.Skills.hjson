ChenSword: {
	1: {
		Label: 赤霄·绝影
		Desc: 对目标发动10次连续斩击，每次造成相当于攻击力320%的物理伤害
	}
}

KroosCrossbow: {
	1: {
		Label: 二连射·自动
		Desc: 下次攻击时连续射击2次，每次射击造成相当于攻击力140%的物理伤害
	}
}

PozemkaCrossbow: {
	1: {
		Label: 抑扬格
		Desc:
			'''
			攻击力+60%，攻击时，40%几率当次攻击的攻击力提升至225%
			持续时间无限
			'''
	}

	2: {
		Label: 点题
		Desc:
			'''
			点击右键立即对前方进行3次攻击，每次造成自身攻击力230%的物理伤害
			可充能2次
			'''
	}

	3: {
		Label: 锐笔速写
		Desc: 攻击间隔缩短，每次攻击的攻击力提升至200%（对25格内的敌人提升至255%）
	}
}

AdnachielCrossbow: {
	1: {
		Label: 攻击力强化·a型
		Desc: 攻击力+50%
	}
}

ExusiaiVector: {
	1: {
		Desc: 下次攻击变为3连射，每次射击造成相当于攻击力145%的伤害
		Label: 冲锋模式
	}

	2: {
		Desc: 攻击变为4连射，每次射击造成相当于攻击力125%的伤害
		Label: 扫射模式
	}

	3: {
		Desc:
			'''
			攻击变为5连射，攻击间隔一定程度缩短，攻击力提升至110%
			技能会自动开启
			'''
		Label: 过载模式
	}
}

KroosAlterCrossbow: {
	1: {
		Desc: 攻击力+40%，攻击变为2连射，大幅降低仇恨值
		Label: 无痕
	}

	2: {
		Label: 封喉
		Desc: 攻击间隔较大幅度缩短，攻击变为2连射，发射32次箭矢后技能剩余时间内攻击变为4连射
	}
}

