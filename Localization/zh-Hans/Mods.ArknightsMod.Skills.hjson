WuQi_Item_JiCi: {
	1: {
		Desc: 攻击力+100%
		Label: 攻击力强化·y型
	}

	2: {
		Label: 护身尖刺
		Desc: 停止攻击，攻击力+60%，防御力+110%，受到敌人攻击时释放尖刺对前方敌人进行一次远程攻击（每0.6秒最多触发一次）
	}

	3: {
		Desc:
			'''
			射弹可达到的最远距离增加并且可追踪目标，攻击力+60%，攻击速度+25，远程攻击不再降低攻击力
			第二次及以后使用时能力加成变为最初的两倍，且持续时间无限
			'''
		Label: 至高之术
	}
}

